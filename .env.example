# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# ── Base de datos ──────────────────────────────────────────────────
# En Dokploy usa el host interno del servicio PostgreSQL
DB_URL=jdbc:postgresql://<host>:5432/<database>
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ── JWT ───────────────────────────────────────────────────────────
# Genera uno nuevo: openssl rand -base64 64
JWT_SECRET=your-base64-secret

# ── Frontend ──────────────────────────────────────────────────────
FRONTEND_URL=https://tu-frontend.tudominio.com

# ── URL pública del backend (sin trailing slash) ───────────────────
APP_BASE_URL=https://api.tudominio.com
